LUDELLUS_PORT=5380
LUDELLUS_PG_URL=postgres://ludellus:ludellus@localhost:5432/ludellus
LUDELLUS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Cernere 連携
CERNERE_BASE_URL=http://localhost:8080
CERNERE_PASETO_AUDIENCE=ludellus
# 公開鍵 (hex)。 設定しない場合は CERNERE_BASE_URL/.well-known/paseto.pub を fetch する。
# どちらも無い場合は unsafe decode フォールバック (dev 専用、 本番では絶対設定する)。
CERNERE_PUBLIC_KEY=

# Memoria 通知 (任意)
MEMORIA_BASE_URL=http://localhost:5180
MEMORIA_SERVICE_TOKEN=

# AI 改修 (free モード、 Phase 3、 任意)
ANTHROPIC_API_KEY=
